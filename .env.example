# ======================================================
# .env.example — Copy this to .env and fill in values
# NEVER commit .env to Git
# ======================================================

# --- Database ---
POSTGRES_DB=employeedb
DB_USERNAME=postgres
DB_PASSWORD=your_strong_password_here

# --- Spring Boot ---
SPRING_PROFILES_ACTIVE=docker
DDL_AUTO=update

# --- JWT (use a long, random secret in production) ---
JWT_SECRET=change_this_to_a_long_random_secret_at_least_256_bits
JWT_EXPIRATION=86400000

# --- AWS ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# --- ECR ---
ECR_REGISTRY=123456789.dkr.ecr.us-east-1.amazonaws.com
ECR_BACKEND_REPO=emp-backend
ECR_FRONTEND_REPO=emp-frontend

# --- EC2 ---
EC2_HOST=your-ec2-public-ip-or-dns
EC2_USERNAME=ec2-user
# EC2_SSH_KEY → add private key content to GitHub Secrets, not here
